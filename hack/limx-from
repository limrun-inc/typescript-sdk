#!/usr/bin/env bash
#
# limx-from: point the `limx` dev binary at a local checkout of this repo.
#
# Builds the SDK + CLI, links the locally built SDK into the CLI, and writes a
# global `limx` shim that runs that checkout's compiled CLI. Use a separate name
# (`limx`) so it never clashes with the real `lim` on your PATH.
#
# Usage:
#   limx-from [REPO_PATH]   build + link the checkout (default: current git toplevel)
#   limx-from --where       print which checkout `limx` currently points at
#   limx-from --unlink      remove the `limx` shim
#   limx-from --help        show this help
#
# After linking:
#   - SDK change:  `yarn build`                     (symlink tracks dist/, no relink)
#   - CLI change:  `yarn --cwd packages/cli build`
#   - check state: `limx --where`
#
# Note: any `npm ci`/`npm install` inside packages/cli restores the registry copy
# of @limrun/api. Re-run `limx-from` to re-link the local build.

set -euo pipefail

readonly BIN_DIR="$HOME/.local/bin"
readonly LIMX="$BIN_DIR/limx"
readonly LIMX_FROM="$BIN_DIR/limx-from"

die() {
  echo "limx-from: $*" >&2
  exit 1
}

cmd_where() {
  if [ ! -x "$LIMX" ]; then
    echo "limx not linked"
    return 0
  fi
  # The shim answers --where itself (prints LIMX_SOURCE), so there is one source of truth.
  "$LIMX" --where
}

cmd_unlink() {
  if [ -f "$LIMX" ]; then
    rm -f "$LIMX"
    echo "removed $LIMX"
    echo "to restore the published SDK copy in a checkout: yarn --cwd <repo>/packages/cli install"
  else
    echo "limx not linked (nothing to remove)"
  fi
}

cmd_help() {
  # Print the contiguous comment header (skip the shebang on line 1).
  awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
}

# Install/refresh the global limx-from command from this script.
# When running the global copy, $0 and $LIMX_FROM are byte-identical, so cmp skips the copy.
self_install() {
  if [ ! -f "$LIMX_FROM" ] || ! cmp -s "$0" "$LIMX_FROM"; then
    cp "$0" "$LIMX_FROM"
    chmod +x "$LIMX_FROM"
    echo "installed global limx-from -> $LIMX_FROM"
  fi
}

cmd_link() {
  local arg="${1:-}"
  local repo
  if [ -n "$arg" ]; then
    repo=$(realpath "$arg" 2>/dev/null) || die "no such path: $arg"
  else
    # --show-toplevel already returns an absolute, canonical path.
    repo=$(git rev-parse --show-toplevel 2>/dev/null) \
      || die "no REPO_PATH given and not inside a git repo"
  fi

  [ -d "$repo" ] || die "not a directory: $repo"
  [ -f "$repo/package.json" ] || die "no package.json at $repo"
  # Pass the path via env, not string interpolation, so quotes/backslashes in it cannot break or inject JS.
  local name
  name=$(REPO="$repo" node -e 'try { process.stdout.write(require(process.env.REPO + "/package.json").name || "") } catch (e) {}')
  [ "$name" = "@limrun/api" ] || die "$repo is not the @limrun/api repo (found name: ${name:-<none>})"
  [ -f "$repo/packages/cli/package.json" ] || die "no packages/cli in $repo"

  # Ensure dependencies are installed (fresh worktrees have no node_modules).
  # Root SDK is yarn-managed; the CLI is npm-managed (CI runs `npm ci` in packages/cli).
  [ -d "$repo/node_modules" ] || yarn --cwd "$repo" install
  [ -d "$repo/packages/cli/node_modules" ] || npm --prefix "$repo/packages/cli" ci

  # Build SDK (via the CLI's prebuild, which runs yarn at the root) then the CLI.
  npm --prefix "$repo/packages/cli" run build

  # Link the locally built SDK into the CLI's node_modules.
  local link="$repo/packages/cli/node_modules/@limrun/api"
  mkdir -p "$(dirname "$link")"
  rm -rf "$link"
  ln -s "$repo/dist" "$link"

  # Write the limx shim. The path is encoded with printf %q so any character in it is safe;
  # the rest is a quoted heredoc (no interpolation).
  mkdir -p "$BIN_DIR"
  {
    echo '#!/usr/bin/env bash'
    echo '# Generated by limx-from. Points limx at a local build; do not edit by hand.'
    printf 'LIMX_SOURCE=%q\n' "$repo"
    cat <<'EOF'
case "${1:-}" in
  --where | where)
    echo "$LIMX_SOURCE"
    exit 0
    ;;
esac
link="$LIMX_SOURCE/packages/cli/node_modules/@limrun/api"
if [ ! -L "$link" ]; then
  echo "limx: local SDK link missing at $link" >&2
  echo "limx: an 'npm ci'/install likely restored the published copy; run 'limx-from \"$LIMX_SOURCE\"' to relink" >&2
  exit 1
fi
exec node "$LIMX_SOURCE/packages/cli/bin/run.js" "$@"
EOF
  } > "$LIMX"
  chmod +x "$LIMX"

  self_install

  echo
  echo "limx -> $repo"
  echo "  SDK: $repo/dist (linked into packages/cli/node_modules/@limrun/api)"
  echo "  CLI: built (bin/run.js)"
  echo "check anytime:  limx --where"
  echo "note: re-run limx-from after any \`npm ci\`/install in packages/cli (it restores the registry copy)"

  case ":$PATH:" in
    *":$BIN_DIR:"*) ;;
    *) echo; echo "warning: $BIN_DIR is not on your PATH; add it to use limx" >&2 ;;
  esac
}

main() {
  case "${1:-}" in
    --where) cmd_where ;;
    --unlink) cmd_unlink ;;
    -h | --help) cmd_help ;;
    -*) die "unknown option: $1 (see --help)" ;;
    *) cmd_link "${1:-}" ;;
  esac
}

main "$@"

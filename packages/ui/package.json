    "directory": "packages/ui"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react-swc": "^4.0.1",
    "jsdom": "^26.0.0",
    "path": "^0.12.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.4",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-lib-inject-css": "^2.2.2",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  }

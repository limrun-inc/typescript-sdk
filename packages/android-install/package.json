{
  "name": "@limrun/android-install",
  "version": "0.1.0",
  "description": "Install APKs on physical Android devices from the browser via QR code or WebUSB (ADB)",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/limrun-inc/typescript-sdk.git",
    "directory": "packages/android-install"
  },
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.12",
    "react": "^19.1.1",
    "typescript": "^5.8.3",
    "vite": "^7.1.4",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@yume-chan/adb": "^2.6.0",
    "@yume-chan/adb-credential-web": "^2.1.0",
    "@yume-chan/adb-daemon-webusb": "^2.3.2",
    "@yume-chan/android-bin": "^2.1.0",
    "qrcode": "^1.5.4"
  }
}

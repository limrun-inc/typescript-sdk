{
  "name": "@limrun/cli",
  "version": "0.2.8",
  "description": "The official CLI for Limrun — create and control cloud mobile sandboxes",
  "bin": {
    "lim": "./bin/run.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/limrun-inc/typescript-sdk.git",
    "directory": "packages/cli"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc",
    "dev": "node bin/dev.js",
    "prepublishOnly": "npm run build",
    "lint": "eslint src/",
    "test": "jest"
  },
  "dependencies": {
    "@limrun/api": "0.24.3",
    "@oclif/core": "^4",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@oclif/test": "^4",
    "@types/cli-progress": "^3.11.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "typescript": "^5.8.3"
  },
  "oclif": {
    "bin": "lim",
    "dirname": "lim",
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "topics": {
      "ios": {
        "description": "Create, manage, and interact with iOS instances"
      },
      "android": {
        "description": "Create, manage, and interact with Android instances"
      },
      "xcode": {
        "description": "Create and manage Xcode sandbox instances"
      },
      "asset": {
        "description": "Upload, download, and manage assets"
      },
      "session": {
        "description": "Manage persistent sessions for fast device interaction"
      },
      "exec": {
        "hidden": true
      },
      "run": {
        "hidden": true
      },
      "get": {
        "hidden": true
      },
      "connect": {
        "hidden": true
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ]
}
